{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/tom2025b/linux-ops-suite/contracts/toolfoundry.rexops-feed.schema.json",
  "title": "ToolFoundry rexops-feed",
  "description": "Attention/health feed emitted by `toolfoundry rexops-feed --json`. Source of truth for tool lifecycle, ownership, and drift state consumed by RexOps. STATUS: REAL — validated against toolfoundry/fixtures/rexops_feed_v1.json.",
  "type": "object",
  "required": ["schema_version", "as_of", "tool_count", "attention_count", "tools"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Integer major version. Bumped only on a breaking change."
    },
    "as_of": {
      "type": "string",
      "description": "Date the feed was generated (YYYY-MM-DD). ToolFoundry's accepted timestamp field; see CONTRACT_RULES.md known deviation."
    },
    "tool_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of tools in the feed."
    },
    "attention_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of tools with status 'attention'."
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_name", "lifecycle_state", "status"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "owner": { "type": "string" },
          "project": { "type": "string" },
          "lifecycle_state": { "type": "string" },
          "review_due": { "type": "boolean" },
          "health_passed": { "type": "integer", "minimum": 0 },
          "health_total": { "type": "integer", "minimum": 0 },
          "drifted": { "type": "boolean" },
          "status": {
            "type": "string",
            "description": "Aggregate state, e.g. 'ok' or 'attention'."
          },
          "manifest_path": { "type": "string" }
        }
      }
    }
  }
}
