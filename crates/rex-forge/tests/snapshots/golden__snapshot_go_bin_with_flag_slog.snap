package main

import (
	"fmt"
	// rex:imports
	"log/slog"
	"os"
	"flag"
)

func main() {
	// rex:init
	logger := slog.New(slog.NewJSONHandler(os.Stderr, nil))
	logger.Info("starting", "app", "myapp")
	name := flag.String("name", "world", "who to greet")
	flag.Parse()
	_ = name
	// rex:main
	fmt.Println("hello from myapp")
}
