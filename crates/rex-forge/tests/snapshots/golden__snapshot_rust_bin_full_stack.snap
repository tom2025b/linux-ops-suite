[dependencies]
anyhow = "1"
tracing = "0.1"

[dependencies.clap]
features = ["derive"]
version = "4"

[dependencies.tracing-subscriber]
features = ["env-filter"]
version = "0.3"

[package]
authors = ["tomb"]
