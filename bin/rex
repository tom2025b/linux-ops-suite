#!/usr/bin/env bash
# rex - Linux Ops Suite reference orchestrator
#
# `rex run` prints the banner then runs the tools in the correct order.
# Tools are invoked if present on PATH; missing tools are skipped.

set -u
set -o pipefail

print_banner() {
    cat << 'BANNER'

      *     .     *     .     *
   *     Rex and Baby Grok built this. Enjoy.     *
      *     .     *     .     *

                 .-""-.
               .'  o o  '.
              /    ^     \
             |   \___/    |
              \          /
               '.      .'
                 '----'
                   ||
                  /  \
                 | RG |
                  \  /
                   ||
                  /  \
                 /    \
                /  /\  \
               (  (  )  )
                '  '  '

      *     .     *     .     *
   *     Rex and Baby Grok built this. Enjoy.     *
      *     .     *     .     *

BANNER
}

run_step() {
    local desc="$1"
    shift
    local cmd="$1"
    shift
    echo "▶ $desc"
    # Resolve the tool: prefer the bare name if it's on PATH (e.g. a `cargo install`ed
    # binary), else fall back to the ~/bin/r-<tool> wrapper from the r-* family. Shell
    # aliases don't exist in a non-interactive script, so the wrapper is what actually
    # makes `workstate`/`toolfoundry`/`bulwark` runnable here.
    local bin=""
    if command -v "$cmd" >/dev/null 2>&1; then
        bin="$cmd"
    elif [ -x "$HOME/bin/r-$cmd" ]; then
        bin="$HOME/bin/r-$cmd"
    fi

    if [ -n "$bin" ]; then
        "$bin" "$@" 2>&1 || echo "  (exited non-zero; continuing)"
    else
        echo "  (not found on PATH or as ~/bin/r-$cmd; skipping)"
    fi
    echo
}

do_run() {
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        project_dir=$(git rev-parse --show-toplevel)
    else
        project_dir=$(pwd)
    fi

    # Workstate publishes its compiled snapshot to the standard path RexOps reads:
    # $XDG_DATA_HOME/rexops/feeds/workstate.snapshot.json (fallback ~/.local/share).
    # We pass this explicitly to `workstate` (its argv[1] override) and then read it
    # back for the summary, so both ends agree on one location.
    local data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
    local snapshot="$data_home/rexops/feeds/workstate.snapshot.json"

    print_banner

    echo "Detected project folder: $project_dir"
    echo "Running full suite of tools in order..."
    echo

    # Order: ToolFoundry -> Bulwark -> Proto -> ScriptVault -> Workstate
    run_step "ToolFoundry" toolfoundry workstate-feed "$project_dir" --as-of "$(date +%F)"
    run_step "Bulwark" bulwark workstate-feed "$project_dir"
    # Proto defaults --dir to a relative `protocols/`, which won't exist in an
    # arbitrary project dir; point it at Proto's own protocol library so the step
    # lists real protocols. If that dir is absent, fall back to the bare default
    # (still degrades gracefully).
    local proto_dir="$HOME/projects/proto/protocols"
    if [ -d "$proto_dir" ]; then
        run_step "Proto" proto --dir "$proto_dir" list
    else
        run_step "Proto" proto list
    fi
    run_step "ScriptVault" scriptvault search
    # Workstate takes NO subcommand: argv[1] is the snapshot output path.
    run_step "Workstate" workstate "$snapshot"

    # Print summary from the Workstate snapshot if available. The snapshot has no
    # `.summary` field; build one from the real shape (built_at + each section's
    # status and record count).
    if command -v jq >/dev/null 2>&1 && [ -f "$snapshot" ]; then
        echo "Suite Summary:"
        jq -r '
            # A section status is either a plain string ("Fresh"/"Stale"/"Missing")
            # or a single-key object ("Failed"/"UnsupportedVersion"); render either
            # as a short label rather than dumping raw JSON mid-line.
            def status_label: if type == "string" then . else (keys[0]) end;
            "  built:    \(.built_at)",
            "  scripts:  \(.scripts.status | status_label)  (\(.scripts.data.scripts | length) record(s))",
            "  tools:    \(.tools.status | status_label)  (\(.tools.data.tool_count // (.tools.data.tools | length) // 0) tool(s))",
            "  findings: \(.findings.status | status_label)  (\(.findings.data.findings | length) finding(s))"
        ' "$snapshot" 2>/dev/null || echo "  (snapshot present but could not be summarized)"
    else
        echo "Suite Summary: (no Workstate snapshot at $snapshot)"
    fi

    echo "Suite run complete."
}

if [ "${1:-}" = "run" ]; then
    do_run
else
    echo "rex — Linux Ops Suite orchestrator (reference)"
    echo "Usage: rex run"
fi
